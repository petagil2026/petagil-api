# ===========================================
# PetÁgil API — Environment Variables Template
# ===========================================
# Arquivo: .env.example
# INSTRUÇÕES:
#   1. Copie para .env:  cp .env.example .env   (Windows: copy .env.example .env)
#   2. Preencha com os valores do seu ambiente (Supabase + segredos JWT)
#   3. NUNCA commite o arquivo .env
# ===========================================

# --- Banco de dados (Supabase / PostgreSQL) ---
# Pegue as strings em: Supabase -> Project Settings -> Database -> Connection string.
#
# DATABASE_URL = conexão POOLED (pgBouncer, porta 6543). Usada pela aplicação em runtime.
#   Mantenha o sufixo ?pgbouncer=true.
#   NÃO use connection_limit=1 aqui (isso é receita serverless/edge e serializaria as
#   queries num servidor Nest persistente). Deixe o pool default do Prisma.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL = conexão DIRETA (porta 5432). Usada por `prisma migrate`.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- JWT ---
# Use segredos fortes e DISTINTOS (ex.: `openssl rand -base64 48`). Mínimo 16 caracteres.
JWT_ACCESS_SECRET="troque-por-um-segredo-forte-de-acesso"
JWT_REFRESH_SECRET="troque-por-um-segredo-forte-de-refresh"

# TTLs (formato aceito pelo @nestjs/jwt). Access curto, refresh longo.
JWT_ACCESS_TTL="900s"   # 15 minutos
JWT_REFRESH_TTL="30d"

# --- Servidor ---
# O app aponta EXPO_PUBLIC_API_BASE_URL=http://localhost:3000 -> manter 3000.
PORT=3000

# CORS: origem(ns) permitida(s). '*' em desenvolvimento.
CORS_ORIGIN="*"

# Ambiente (opcional): development | test | production
NODE_ENV="development"
