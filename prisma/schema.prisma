// Prisma schema — PetÁgil API
// Datasource: PostgreSQL no Supabase.
//   url       -> conexão "pooled" (pgBouncer :6543, com ?pgbouncer=true) usada pela aplicação.
//   directUrl -> conexão direta (:5432) usada por `prisma migrate`.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  TUTOR
  VET
  PASSEADOR
}

enum Species {
  DOG
  CAT
  BIRD
  REPTILE
}

enum VetVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AvailabilityPeriod {
  MORNING
  AFTERNOON
  NIGHT
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  // Contato coletado no cadastro de conta ("Crie sua conta"). Nullable para não
  // quebrar usuários/seed pré-existentes; o formulário novo sempre os envia.
  phone        String?
  city         String?
  // Papel "primário" escolhido no signup. O que o usuário PODE fazer é definido
  // pelos perfis abaixo (multi-perfil: pode ter mais de um).
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tutorProfile  TutorProfile?
  vetProfile    VetProfile?
  walkerProfile WalkerProfile?
  pets          Pet[]
}

/// Perfil de Tutor (dono de pet). 1:1 opcional com User.
model TutorProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsapp  String
  city      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Perfil de Clínica veterinária (papel `vet`). CNPJ da clínica + CRMV do
/// responsável técnico. 1:1 opcional com User.
model VetProfile {
  id             String                @id @default(uuid())
  userId         String                @unique
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  photoUrl       String?
  // CNPJ da clínica (14 dígitos, sem máscara). Nullable p/ não quebrar linhas
  // pré-pivô; o cadastro novo sempre envia. Único: uma clínica por CNPJ.
  cnpj           String?               @unique
  // CRMV do responsável técnico da clínica.
  crmvNumber     String
  crmvUf         String
  specialties    String[] // ex.: "Clínica geral", "Silvestres"
  bio            String?
  servesAtClinic Boolean               @default(false)
  servesAtHome   Boolean               @default(false)
  clinicName     String?
  clinicAddress  String?
  crmvDocUrl     String? // carteira do CRMV anexada (opcional)
  verification   VetVerificationStatus @default(PENDING)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  availability VetAvailability?
  timeOffs     VetTimeOff[]

  @@unique([crmvNumber, crmvUf])
}

/// Regra de disponibilidade recorrente da clínica (vet). 1:1 com VetProfile.
/// `weekdays` usa a ordem da UI (0=Segunda … 6=Domingo), NÃO o Date.getDay() do JS.
model VetAvailability {
  id              String                  @id @default(uuid())
  vetProfileId    String                  @unique
  vetProfile      VetProfile              @relation(fields: [vetProfileId], references: [id], onDelete: Cascade)
  weekdays        Int[] // 0=Seg … 6=Dom (ordem da UI)
  slotDurationMin Int                     @default(30) // ∈ {20,30,45,60}
  periods         VetAvailabilityPeriod[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}

/// Período habilitado (manhã/tarde/noite) de uma disponibilidade. N:1 com VetAvailability.
/// `startMinute`/`endMinute` são minutos-do-dia (0..1440) — sem timezone.
model VetAvailabilityPeriod {
  id             String             @id @default(uuid())
  availabilityId String
  availability   VetAvailability    @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  period         AvailabilityPeriod
  startMinute    Int
  endMinute      Int

  @@unique([availabilityId, period])
}

/// Folga/bloqueio da clínica (vet). N:1 com VetProfile.
/// Cobre "dia inteiro" (multi-dia) e "faixa de horário". `startsAt`/`endsAt` são instantes UTC.
model VetTimeOff {
  id           String     @id @default(uuid())
  vetProfileId String
  vetProfile   VetProfile @relation(fields: [vetProfileId], references: [id], onDelete: Cascade)
  startsAt     DateTime
  endsAt       DateTime
  allDay       Boolean    @default(false)
  reason       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([vetProfileId])
}

/// Perfil de Passeador (dog walker). 1:1 opcional com User.
model WalkerProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  photoUrl     String?
  city         String
  bio          String?
  petTypes     String[] // ex.: "Cães", "Gatos", "Pequenos"
  region       String
  pricePerWalk Int // em centavos de BRL
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Pet do tutor. N:1 com User (dono).
model Pet {
  id           String        @id @default(uuid())
  ownerId      String
  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name         String
  species      Species
  breed        String?
  ageYears     Int?
  photoUrl     String?
  vaccinations Vaccination[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([ownerId])
}

/// Item da carteira de vacinação de um Pet.
model Vaccination {
  id         String    @id @default(uuid())
  petId      String
  pet        Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  name       String
  date       DateTime?
  nextDoseAt DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([petId])
}
